# Never send node_modules — installed fresh inside the container
node_modules
**/node_modules

# TypeScript build output — rebuilt fresh inside the container
**/dist

# Next.js build cache
apps/web/.next
apps/web/.turbo

# Turborepo cache
.turbo
**/.turbo

# Git
.git
.gitignore

# Logs
**/*.log
npm-debug.log*

# Environment files — never bake secrets into images
.env
.env.local
.env.production

# IDE / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Local repos cloned by the agent
repos/
