{
  "name": "@issuepilot/api",
  "version": "1.0.0",
  "description": "IssuePilot API server",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@issuepilot/agent": "workspace:*",
    "@issuepilot/llm": "workspace:*",
    "@issuepilot/github": "workspace:*",
    "@issuepilot/sandbox": "workspace:*",
    "@octokit/rest": "^21.0.0",
    "@issuepilot/vector": "workspace:*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.0",
    "drizzle-orm": "^0.31.0",
    "drizzle-kit": "0.21.4",
    "pg": "^8.12.0",
    "bullmq": "^5.7.0",
    "ioredis": "^5.4.0",
    "jose": "^5.4.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.0",
    "tsx": "^4.11.0"
  }
}
